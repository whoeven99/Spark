{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/server",
    "rootDir": "server",
    "resolveJsonModule": true
  },
  "include": ["server"],
  "exclude": ["node_modules", "dist"]
}
