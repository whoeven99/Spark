// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // 生成到 node_modules 外，避免 Windows 上 query_engine 重命名 EPERM（Defender/进程占用 .prisma 目录）
  output   = "../app/generated/prisma"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shop])
}

model Suggestion {
  id        String   @id @default(cuid())
  shop      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, createdAt])
}

model AdPlatformCredential {
  id          String   @id @default(cuid())
  shop        String
  platform    String
  credentials Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, platform])
}

/// GMC 商品审核状态缓存（同步后即时查 / 30 分钟延迟查 / 每日 cron 写入）。
model GmcProductStatus {
  id               String   @id @default(cuid())
  shop             String
  merchantId       String
  offerId          String
  shopifyProductId String?
  title            String?
  status           String
  issues           Json?
  checkedAt        DateTime
  updatedAt        DateTime @updatedAt

  @@unique([shop, offerId])
  @@index([shop, status])
  @@index([shop, merchantId])
}

/// Meta（Facebook）Catalog 商品审核状态缓存（同步后即时查 / 30 分钟延迟查 / 每日 cron 写入）。
model MetaProductStatus {
  id               String   @id @default(cuid())
  shop             String
  catalogId        String
  retailerId       String
  shopifyProductId String?
  title            String?
  status           String
  issues           Json?
  checkedAt        DateTime
  updatedAt        DateTime @updatedAt

  @@unique([shop, retailerId])
  @@index([shop, status])
  @@index([shop, catalogId])
}

/// 店铺账户（token 分池 + 用量）。
model Account {
  id                 String   @id @default(cuid())
  shop               String
  /// 当前订阅周期套餐 token（周期内不随用量减少；续费刷新）
  subscriptionTokens Int      @default(0)
  /// 按量购买 token（续费结算后写入真实剩余；周期内不随用量减少）
  purchasedTokens    Int      @default(0)
  /// 产品层免费试用 token（续费结算后写入真实剩余）
  trialTokens        Int      @default(0)
  /// 本周期累计已用 token（续费清零；续费时用于结算按量包剩余）
  usedTokens         Int      @default(0)
  /// Shopify 试用期当日已用 token（每日 UTC 0 点重置）
  trialDailyUsed     Int      @default(0)
  /// 上次重置 trialDailyUsed 的日期（UTC 0 点）
  trialDailyResetAt  DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  appSubscription   AppSubscription?
  periodUsages      AccountPeriodUsage[]
  billingLogs       BillingLog[]
  toolTokenUsageLogs ToolTokenUsageLog[]

  @@unique([shop])
}

/// 套餐目录（订阅 / 按量包 / 内置试用定义）。
model PlanCatalog {
  planKey          String   @id
  /// SUBSCRIPTION | ONE_TIME_PACK | INTERNAL_TRIAL
  kind             String
  /// MONTHLY | ANNUAL；一次性包为 null
  billingInterval  String?
  displayName      String
  tokens           Int
  priceAmount      String
  currencyCode     String   @default("USD")
  trialDays        Int?
  shopifyPlanName  String?
  sortOrder        Int      @default(0)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([enabled, sortOrder])
}

/// 当前生效的 Shopify 订阅（每 shop 一条）。
model AppSubscription {
  id                     String   @id @default(cuid())
  shop                   String
  planKey                String
  shopifySubscriptionId  String   @unique
  billingInterval        String
  /// PENDING | ACTIVE | CANCELLED | EXPIRED | FROZEN
  status                 String
  tokensPerPeriod        Int
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  confirmationUrl        String?
  rawPayload             Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  account      Account?             @relation(fields: [shop], references: [shop])
  periodUsages AccountPeriodUsage[]

  @@unique([shop])
  @@index([status])
}

/// 每个订阅周期结束时的 token 用量归档（续费时写入）。
model AccountPeriodUsage {
  id                          String   @id @default(cuid())
  shop                        String
  appSubscriptionId           String
  planKey                     String
  periodStart                 DateTime
  periodEnd                   DateTime
  usedTokens                  Int
  subscriptionTokensAllocated Int
  purchasedTokensRemaining    Int      @default(0)
  trialTokensRemaining        Int      @default(0)
  archivedAt                  DateTime @default(now())

  account        Account         @relation(fields: [shop], references: [shop])
  appSubscription AppSubscription @relation(fields: [appSubscriptionId], references: [id])

  @@unique([appSubscriptionId, periodStart, periodEnd])
  @@index([shop, periodEnd])
}

/// App 通用事件流水：安装、卸载、scope 变更等（与 BillingLog 计费语义分离）。
model CommonEventLog {
  id          String   @id @default(cuid())
  shop        String
  /// APP_INSTALLED | APP_UNINSTALLED | SCOPES_UPDATE
  eventType   String
  /// Shopify webhook topic，如 app/uninstalled
  topic       String?
  /// 幂等键（如 session id、webhook id）
  referenceId String?
  payload     Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([shop, createdAt])
  @@index([eventType, createdAt])
  @@index([referenceId])
}

/// 入口来源归因：用户从带 utm 参数的外链（邮件 / 广告等）首次进入 App 时记一条。
/// Shopify 仅在带参链接首次进入时透传 query，站内导航会丢弃，因此天然只记录外部入口。
model AppVisitSource {
  id        String   @id @default(cuid())
  shop      String
  /// 落地 path，如 /app/product-improve
  path      String
  /// 原始 utm 字符串，如 email（保留原值，不在写入时解析）
  utm       String
  /// 整段 query string 兜底（如 ?utm=email），未来 utm 变复杂也不丢信息
  query     String?
  /// HTTP Referer（若有）
  referer   String?
  createdAt DateTime @default(now())

  @@index([shop, createdAt])
  @@index([utm, createdAt])
  @@index([utm, path])
}

/// 计费流水：试用、订阅、续费、按量购 token 等。
model BillingLog {
  id          String   @id @default(cuid())
  shop        String
  /// TRIAL_GRANTED | SUBSCRIPTION_ACTIVATED | SUBSCRIPTION_RENEWED | TOKEN_PACK_PURCHASED
  eventType   String
  planKey     String?
  referenceId String?
  tokensDelta Int?
  usedTokens  Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  account Account @relation(fields: [shop], references: [shop])

  @@index([shop, createdAt])
  @@index([eventType, createdAt])
  @@index([referenceId])
}

/// 工具 token 明细：每次工具调用入账一条（高频），与 BillingLog 账务事件拆分。
model ToolTokenUsageLog {
  id          String   @id @default(cuid())
  shop        String
  feature     String
  modelKey    String
  rawTokens   Int
  billedTokens Int
  inputTokens Int      @default(0)
  outputTokens Int     @default(0)
  createdAt   DateTime @default(now())

  account Account @relation(fields: [shop], references: [shop])

  @@index([shop, createdAt])
  @@index([shop, feature, createdAt])
  @@index([feature, createdAt])
}

/// AI 任务「单位(per-item)成本」EWMA 估算，按 (taskType, bucket) 分桶，随真实运行自校准。
model AITaskEstimation {
  id           String   @id @default(cuid())
  /// image_generation | picture_translate | product_improve | translation
  taskType     String
  /// 规模特征分桶：如 product_improve 按文本长度、picture_translate 按 modelType、translation 按目标语言。老数据/无特征落 "default"。
  bucket       String   @default("default")
  /// EWMA 预估积分（per-item，收敛后替换硬编码默认值）
  ewmaCredits  Float?
  /// EWMA 预估耗时（秒，per-item）
  ewmaSeconds  Float?
  /// 已参与统计的样本数（前5条用简单均值 bootstrap）
  sampleCount  Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([taskType, bucket])
}

/// AI 任务批次：一次提交对应一个批次（含单任务）。
model AITaskBatch {
  id        String   @id @default(uuid())
  shop      String
  /// image_generation | picture_translate
  taskType  String
  config    Json
  tasks     AITask[]
  createdAt DateTime @default(now())

  @@index([shop, createdAt])
}

/// AI 任务：每个商品/图片对应一条，归属于某批次。
model AITask {
  id               String      @id @default(uuid())
  shop             String
  /// image_generation | picture_translate
  taskType         String
  batchId          String
  batch            AITaskBatch @relation(fields: [batchId], references: [id])
  /// running | succeeded | failed | cancelled
  status           String
  config           Json
  result           Json?
  estimatedCredits Int?
  actualCredits    Int?
  startedAt        DateTime    @default(now())
  completedAt      DateTime?
  errorMsg         String?
  logs             AITaskLog[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([shop, taskType, createdAt])
  @@index([batchId])
}

/// AI 任务日志：每条为一个时间戳 + 消息，支持 SSE 流式推送。
model AITaskLog {
  id             String   @id @default(uuid())
  taskId         String
  task           AITask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  elapsedSeconds Int
  message        String
  createdAt      DateTime @default(now())

  @@index([taskId, createdAt])
}

/// 电商订单（增量同步自 Shopify Webhook + 历史回补）。
model ShopOrder {
  id                String    @id @default(cuid())
  shop              String
  shopifyOrderId    String
  orderNumber       Int
  email             String?
  /// paid | partially_refunded | refunded | voided | pending | authorized | partially_paid
  financialStatus   String?
  /// unfulfilled | partial | fulfilled | restocked
  fulfillmentStatus String?
  /// open | archived | cancelled
  status            String    @default("open")
  currency          String
  totalPrice        Float
  subtotalPrice     Float     @default(0)
  totalDiscounts    Float     @default(0)
  totalTax          Float     @default(0)
  totalShipping     Float     @default(0)
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime
  updatedAt         DateTime
  processedAt       DateTime?
  paidAt            DateTime?
  closedAt          DateTime?
  shopifyCustomerId String?
  customerFirstName String?
  customerLastName  String?
  customerEmail     String?
  tags              String?
  sourceName        String?
  landingSite       String?
  referringSite     String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  isFirstOrder      Boolean   @default(false)
  syncedAt          DateTime  @default(now())

  lineItems    ShopOrderLineItem[]
  refunds      ShopRefund[]
  refundLineItems ShopRefundLineItem[]
  fulfillments ShopFulfillment[]

  @@unique([shop, shopifyOrderId])
  @@index([shop, createdAt])
  @@index([shop, paidAt])
  @@index([shop, financialStatus])
  @@index([shop, shopifyCustomerId])
}

/// 订单行项目（每个 SKU 一条）。
model ShopOrderLineItem {
  id             String  @id @default(cuid())
  shop           String
  shopifyOrderId String
  lineItemId     String
  inventoryItemId String?
  variantId      String?
  productId      String?
  title          String
  variantTitle   String?
  sku            String?
  quantity       Int
  price          Float
  totalDiscount  Float   @default(0)
  vendor         String?

  order ShopOrder @relation(fields: [shop, shopifyOrderId], references: [shop, shopifyOrderId])

  @@unique([shop, lineItemId])
  @@index([shop, shopifyOrderId])
  @@index([shop, sku])
  @@index([shop, inventoryItemId])
  @@index([shop, productId])
}

/// 退款记录（含部分退款）。
model ShopRefund {
  id              String   @id @default(cuid())
  shop            String
  shopifyRefundId String
  shopifyOrderId  String
  refundAmount    Float    @default(0)
  shippingRefundAmount Float @default(0)
  shippingRefundTax    Float @default(0)
  refundNote      String?
  reason          String?
  processedAt     DateTime
  createdAt       DateTime
  syncedAt        DateTime @default(now())

  order     ShopOrder            @relation(fields: [shop, shopifyOrderId], references: [shop, shopifyOrderId])
  lineItems ShopRefundLineItem[]

  @@unique([shop, shopifyRefundId])
  @@index([shop, shopifyOrderId])
  @@index([shop, processedAt])
}

/// 閫€娆捐椤圭洰锛岀敤浜?SKU 褰掑洜銆侀€€娆鹃噾棰?Top SKU 鍜屽敭鍚庡缓璁€?
model ShopRefundLineItem {
  id              String @id @default(cuid())
  shop            String
  shopifyRefundId String
  shopifyOrderId  String
  refundLineItemId String
  lineItemId      String
  inventoryItemId String?
  variantId       String?
  productId       String?
  title           String?
  variantTitle    String?
  sku             String?
  quantity        Int    @default(0)
  subtotal        Float  @default(0)
  totalTax        Float  @default(0)
  reason          String?
  restockType     String?
  createdAt       DateTime @default(now())
  syncedAt        DateTime @default(now())

  refund ShopRefund @relation(fields: [shop, shopifyRefundId], references: [shop, shopifyRefundId], onDelete: Cascade)
  order   ShopOrder  @relation(fields: [shop, shopifyOrderId], references: [shop, shopifyOrderId])

  @@unique([shop, refundLineItemId])
  @@index([shop, shopifyRefundId])
  @@index([shop, shopifyOrderId])
  @@index([shop, lineItemId])
  @@index([shop, sku])
  @@index([shop, reason])
}

/// 客户信息快照（首单/末单/LTV）。
model ShopCustomer {
  id                String    @id @default(cuid())
  shop              String
  shopifyCustomerId String
  email             String?
  phone             String?
  firstName         String?
  lastName          String?
  ordersCount       Int       @default(0)
  totalSpent        Float     @default(0)
  firstOrderDate    DateTime?
  lastOrderDate     DateTime?
  /// active | disabled | declined
  state             String?
  tags              String?
  acceptsMarketing  Boolean   @default(false)
  createdAt         DateTime
  updatedAt         DateTime
  syncedAt          DateTime  @default(now())

  @@unique([shop, shopifyCustomerId])
  @@index([shop, email])
  @@index([shop, firstOrderDate])
  @@index([shop, lastOrderDate])
}

/// 多仓库存水位（按 inventory_item × location）。
model ShopInventoryLevel {
  id              String   @id @default(cuid())
  shop            String
  inventoryItemId String
  variantId       String?
  productId       String?
  sku             String?
  productTitle    String?
  variantTitle    String?
  locationId      String
  locationName    String?
  available       Int      @default(0)
  onHand          Int      @default(0)
  committed       Int      @default(0)
  incoming        Int      @default(0)
  updatedAt       DateTime
  syncedAt        DateTime @default(now())

  @@unique([shop, inventoryItemId, locationId])
  @@index([shop, sku])
  @@index([shop, variantId])
  @@index([shop, locationId])
  @@index([shop, available])
}

/// 发货履约记录。
model ShopFulfillment {
  id                   String   @id @default(cuid())
  shop                 String
  shopifyFulfillmentId String
  shopifyOrderId       String
  /// pending | open | success | cancelled | error | failure
  status               String
  trackingCompany      String?
  trackingNumber       String?
  trackingUrl          String?
  /// pre_transit | in_transit | out_for_delivery | delivered | failure
  shipmentStatus       String?
  createdAt            DateTime
  updatedAt            DateTime
  shippedAt            DateTime?
  deliveredAt          DateTime?
  syncedAt             DateTime @default(now())

  order ShopOrder @relation(fields: [shop, shopifyOrderId], references: [shop, shopifyOrderId])

  @@unique([shop, shopifyFulfillmentId])
  @@index([shop, shopifyOrderId])
  @@index([shop, status])
  @@index([shop, createdAt])
}

/// 增量同步游标（记录每类资源的最后同步时间/分页游标）。
model ShopSyncCheckpoint {
  id           String   @id @default(cuid())
  shop         String
  /// orders | refunds | customers | inventory | fulfillments
  resource     String
  lastSyncedAt DateTime
  lastCursor   String?
  updatedAt    DateTime @updatedAt

  @@unique([shop, resource])
}

/// 工作台上传文件（原始文件 + 解析文本均存 Azure Blob，元数据存本表）。
model WorkspaceFile {
  id               String   @id @default(cuid())
  shop             String
  name             String
  mimeType         String   @default("")
  originalSize     Int
  charCount        Int
  /// 解析后文本的 Blob 路径
  blobPath         String
  /// 原始文件的 Blob 路径（用于下载）
  originalBlobPath String   @default("")
  createdAt        DateTime @default(now())

  @@index([shop, createdAt])
}

/// AI 对话会话（每条对应一个聊天线程）。
model Conversation {
  id        String    @id @default(cuid())
  shop      String
  title     String    @default("新对话")
  preview   String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([shop, updatedAt(sort: Desc)])
}

/// 对话消息（追加写入，不可变）。
model Message {
  id             String       @id @default(cuid())
  conversationId String
  /// "user" | "assistant"
  role           String
  content        String
  /// JSON: translationTaskForm, attachments, productImproveCard, etc.
  payloads       String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

/// 业务能力 × 模型/提供商的 token 计费系数（运维在 Turso 维护，种子见 `prisma/token-billing-rule-seed.sql`）。
model TokenBillingRule {
  ruleKey       String   @id
  /// product_copy | image_prompt | image_generate | picture_translate
  feature       String
  /// 模型标识（如 deepseek-chat、volc-translate）；`_default` 为该 feature 下未匹配模型时的兜底
  modelKey      String
  displayName   String
  /// 记入 Account.usedTokens 前对 token 的乘数（≥0）
  multiplier    Float
  /// 定额计费时的基准 token（可选；未设则用代码内环境变量默认）
  baseTokenCost Int?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([feature, modelKey])
  @@index([feature, enabled])
}

/// 每日经营诊断快照（每店每天一份，docs/DAILY_OPERATIONS_WORKFLOWS.md §11）。
model OperationDiagnosisSnapshot {
  id           String   @id @default(cuid())
  shop         String
  /// 快照日期（UTC，格式 YYYY-MM-DD）
  snapshotDate String
  /// 是否有可诊断数据（店铺尚未回填订单时为 false）
  hasData      Boolean  @default(true)
  /// 汇总指标 JSON：订单数/GMV/AOV/退款率/履约率/超时单数等
  metrics      Json
  generatedAt  DateTime @default(now())

  items OperationDiagnosisItem[]
  tasks OperationTask[]

  @@unique([shop, snapshotDate])
  @@index([shop, generatedAt])
}

/// 单个诊断项（销售趋势/履约健康/物流异常/退款售后/库存健康）。
model OperationDiagnosisItem {
  id         String @id @default(cuid())
  shop       String
  snapshotId String
  /// sales_trend | fulfillment_health | logistics_anomaly | refund_health | inventory_health
  key        String
  name       String
  /// healthy | watch | risk
  status     String
  /// 指标明细 JSON
  metrics    Json
  /// 证据（字符串数组）
  evidence   Json
  /// 推理链（字符串数组）
  reasoning  Json
  /// 使用的计算公式（字符串数组）
  formulas   Json

  snapshot OperationDiagnosisSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([shop, key])
  @@index([snapshotId])
}

/// 经营待办任务（由诊断规则生成，按紧急/重要四象限组织）。
model OperationTask {
  id               String    @id @default(cuid())
  shop             String
  snapshotId       String?
  /// 来源规则键：fulfillment_overdue | logistics_stale | refund_spike | inventory_risk | routine_shipping | sales_decline
  sourceKey        String
  /// 去重键（sourceKey + 关联对象），同一问题在 open/in_progress 状态下只保留一条
  dedupeKey        String
  title            String
  /// q1（紧急重要）| q2（紧急不重要）| q3（不紧急重要）| q4（不紧急不重要）
  quadrant         String
  /// P0 | P1 | P2
  priority         String
  /// open | in_progress | done | ignored | auto_closed
  status           String    @default("open")
  /// 触发原因（含证据数字）
  triggerReason    String
  /// 关联对象 JSON：订单号 / SKU 列表等
  relatedObjects   Json
  /// 建议动作（字符串数组）
  suggestedActions Json
  ownerRole        String?
  /// today | 48h | this_week | backlog
  dueWindow        String
  dueAt            DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  snapshot OperationDiagnosisSnapshot? @relation(fields: [snapshotId], references: [id])

  @@index([shop, status, quadrant])
  @@index([shop, dedupeKey, status])
  @@index([shop, createdAt])
}

/// 店铺成本口径配置（ROI 核算用，docs/DAILY_OPERATIONS_WORKFLOWS.md §8.8 成本完整度）。
model ShopCostConfig {
  id   String @id @default(cuid())
  shop String @unique
  /// 默认毛利率（%），无逐 SKU 成本时的兜底口径
  defaultGrossMarginPercent Float    @default(60)
  /// 支付手续费率（%）
  paymentFeePercent         Float    @default(2.9)
  /// 单笔支付固定手续费
  paymentFeeFixed           Float    @default(0.3)
  /// 月度固定投入（内容/工具/人力），用于后续投入成本分摊
  monthlyFixedCost          Float    @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

/// SKU 单位成本（同步自 Shopify inventoryItem.unitCost，逐 SKU COGS）。
model ShopSkuCost {
  id              String   @id @default(cuid())
  shop            String
  inventoryItemId String
  variantId       String?
  sku             String?
  unitCost        Float
  currency        String?
  syncedAt        DateTime @default(now())

  @@unique([shop, inventoryItemId])
  @@index([shop, sku])
}

/// 客户价值快照（最新状态，每日巡检懒刷新；§8.5.1 客户动态计价）。
model ShopCustomerValue {
  id                    String    @id @default(cuid())
  shop                  String
  shopifyCustomerId     String
  /// new | active | vip | at_risk | churned
  segment               String
  /// 风险标签数组：refund_risk | discount_sensitive
  tags                  Json
  ordersCount           Int       @default(0)
  totalSpent            Float     @default(0)
  /// 历史贡献利润（毛利率近似口径）
  realizedGrossProfit   Float     @default(0)
  /// 规则近似的未来贡献利润
  predictedFutureProfit Float     @default(0)
  dynamicLtv            Float     @default(0)
  /// 0-100 综合管理分（§8.5.10）
  customerValueScore    Float     @default(0)
  refundAmount          Float     @default(0)
  /// 客户退款率（退款额/消费额，%）
  refundRate            Float     @default(0)
  /// 折扣订单占比（%）
  discountOrderShare    Float     @default(0)
  daysSinceLastOrder    Int?
  firstOrderAt          DateTime?
  lastOrderAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([shop, shopifyCustomerId])
  @@index([shop, segment])
  @@index([shop, customerValueScore])
}
