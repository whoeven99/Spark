// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // 生成到 node_modules 外，避免 Windows 上 query_engine 重命名 EPERM（Defender/进程占用 .prisma 目录）
  output   = "../app/generated/prisma"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

/// 卫星 App（generate-description）Session，与主 App `Session` 同库分表。
model GenerateDescriptionSession {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@map("Session_generate_description")
}

model Suggestion {
  id        String   @id @default(cuid())
  shop      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, createdAt])
}

model AdPlatformCredential {
  id          String   @id @default(cuid())
  shop        String
  platform    String
  credentials Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, platform])
}
