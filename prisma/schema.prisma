// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // 生成到 node_modules 外，避免 Windows 上 query_engine 重命名 EPERM（Defender/进程占用 .prisma 目录）
  output   = "../app/generated/prisma"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  appName       String    @default("chat")
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
  shopName       String?
  shopOwnerName  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([appName, shop])
}

model Suggestion {
  id        String   @id @default(cuid())
  shop      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, createdAt])
}

model AdPlatformCredential {
  id          String   @id @default(cuid())
  shop        String
  platform    String
  credentials Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, platform])
}

/// 店铺在各 App 入口下的账户（token 分池 + 用量）。
model Account {
  id                 String   @id @default(cuid())
  shop               String
  /// 与 `AppEntry` 一致，如 chat、product-improve
  appName            String
  /// 当前订阅周期套餐 token（周期内不随用量减少；续费刷新）
  subscriptionTokens Int      @default(0)
  /// 按量购买 token（续费结算后写入真实剩余；周期内不随用量减少）
  purchasedTokens    Int      @default(0)
  /// 产品层免费试用 token（续费结算后写入真实剩余）
  trialTokens        Int      @default(0)
  /// 本周期累计已用 token（续费清零；续费时用于结算按量包剩余）
  usedTokens         Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  appSubscription   AppSubscription?
  periodUsages      AccountPeriodUsage[]
  billingLogs       BillingLog[]
  toolTokenUsageLogs ToolTokenUsageLog[]

  @@unique([shop, appName])
  @@index([shop])
}

/// 套餐目录（订阅 / 按量包 / 内置试用定义）。
model PlanCatalog {
  planKey          String   @id
  appName          String
  /// SUBSCRIPTION | ONE_TIME_PACK | INTERNAL_TRIAL
  kind             String
  /// MONTHLY | ANNUAL；一次性包为 null
  billingInterval  String?
  displayName      String
  tokens           Int
  priceAmount      String
  currencyCode     String   @default("USD")
  trialDays        Int?
  shopifyPlanName  String?
  sortOrder        Int      @default(0)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([appName, enabled, sortOrder])
}

/// 当前生效的 Shopify 订阅（每 shop + appName 一条）。
model AppSubscription {
  id                     String   @id @default(cuid())
  shop                   String
  appName                String
  planKey                String
  shopifySubscriptionId  String   @unique
  billingInterval        String
  /// PENDING | ACTIVE | CANCELLED | EXPIRED | FROZEN
  status                 String
  tokensPerPeriod        Int
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  confirmationUrl        String?
  rawPayload             Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  account      Account?             @relation(fields: [shop, appName], references: [shop, appName])
  periodUsages AccountPeriodUsage[]

  @@unique([shop, appName])
  @@index([status])
}

/// 每个订阅周期结束时的 token 用量归档（续费时写入）。
model AccountPeriodUsage {
  id                          String   @id @default(cuid())
  shop                        String
  appName                     String
  appSubscriptionId           String
  planKey                     String
  periodStart                 DateTime
  periodEnd                   DateTime
  usedTokens                  Int
  subscriptionTokensAllocated Int
  purchasedTokensRemaining    Int      @default(0)
  trialTokensRemaining        Int      @default(0)
  archivedAt                  DateTime @default(now())

  account        Account         @relation(fields: [shop, appName], references: [shop, appName])
  appSubscription AppSubscription @relation(fields: [appSubscriptionId], references: [id])

  @@unique([appSubscriptionId, periodStart, periodEnd])
  @@index([shop, appName, periodEnd])
}

/// App 通用事件流水：安装、卸载、scope 变更等（与 BillingLog 计费语义分离）。
model CommonEventLog {
  id          String   @id @default(cuid())
  shop        String
  /// 与 `AppEntry` 一致
  appName     String
  /// APP_INSTALLED | APP_UNINSTALLED | SCOPES_UPDATE
  eventType   String
  /// Shopify webhook topic，如 app/uninstalled
  topic       String?
  /// 幂等键（如 session id、webhook id）
  referenceId String?
  payload     Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([shop, appName, createdAt])
  @@index([eventType, createdAt])
  @@index([referenceId])
}

/// 入口来源归因：用户从带 utm 参数的外链（邮件 / 广告等）首次进入 App 时记一条。
/// Shopify 仅在带参链接首次进入时透传 query，站内导航会丢弃，因此天然只记录外部入口。
model AppVisitSource {
  id        String   @id @default(cuid())
  shop      String
  /// 与 `AppEntry` 一致
  appName   String
  /// 落地 path，如 /app/product-improve
  path      String
  /// 原始 utm 字符串，如 email（保留原值，不在写入时解析）
  utm       String
  /// 整段 query string 兜底（如 ?utm=email），未来 utm 变复杂也不丢信息
  query     String?
  /// HTTP Referer（若有）
  referer   String?
  createdAt DateTime @default(now())

  @@index([shop, createdAt])
  @@index([appName, utm, createdAt])
  @@index([utm, path])
}

/// 计费流水：试用、订阅、续费、按量购 token 等。
model BillingLog {
  id          String   @id @default(cuid())
  shop        String
  appName     String
  /// TRIAL_GRANTED | SUBSCRIPTION_ACTIVATED | SUBSCRIPTION_RENEWED | TOKEN_PACK_PURCHASED
  eventType   String
  planKey     String?
  referenceId String?
  tokensDelta Int?
  usedTokens  Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  account Account @relation(fields: [shop, appName], references: [shop, appName])

  @@index([shop, appName, createdAt])
  @@index([eventType, createdAt])
  @@index([referenceId])
}

/// 工具 token 明细：每次工具调用入账一条（高频），与 BillingLog 账务事件拆分。
model ToolTokenUsageLog {
  id          String   @id @default(cuid())
  shop        String
  appName     String
  feature     String
  modelKey    String
  rawTokens   Int
  billedTokens Int
  inputTokens Int      @default(0)
  outputTokens Int     @default(0)
  createdAt   DateTime @default(now())

  account Account @relation(fields: [shop, appName], references: [shop, appName])

  @@index([shop, appName, createdAt])
  @@index([shop, appName, feature, createdAt])
  @@index([feature, createdAt])
}

/// AI 任务批次：一次提交对应一个批次（含单任务）。
model AITaskBatch {
  id        String   @id @default(uuid())
  shop      String
  appName   String
  /// image_generation | picture_translate
  taskType  String
  config    Json
  tasks     AITask[]
  createdAt DateTime @default(now())

  @@index([shop, appName, createdAt])
}

/// AI 任务：每个商品/图片对应一条，归属于某批次。
model AITask {
  id               String      @id @default(uuid())
  shop             String
  appName          String
  /// image_generation | picture_translate
  taskType         String
  batchId          String
  batch            AITaskBatch @relation(fields: [batchId], references: [id])
  /// running | succeeded | failed | cancelled
  status           String
  config           Json
  result           Json?
  estimatedCredits Int?
  actualCredits    Int?
  startedAt        DateTime    @default(now())
  completedAt      DateTime?
  errorMsg         String?
  logs             AITaskLog[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([shop, appName, taskType, createdAt])
  @@index([batchId])
}

/// AI 任务日志：每条为一个时间戳 + 消息，支持 SSE 流式推送。
model AITaskLog {
  id             String   @id @default(uuid())
  taskId         String
  task           AITask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  elapsedSeconds Int
  message        String
  createdAt      DateTime @default(now())

  @@index([taskId, createdAt])
}

/// 电商订单（增量同步自 Shopify Webhook + 历史回补）。
model ShopOrder {
  id                String    @id @default(cuid())
  shop              String
  shopifyOrderId    String
  orderNumber       Int
  email             String?
  /// paid | partially_refunded | refunded | voided | pending | authorized | partially_paid
  financialStatus   String?
  /// unfulfilled | partial | fulfilled | restocked
  fulfillmentStatus String?
  /// open | archived | cancelled
  status            String    @default("open")
  currency          String
  totalPrice        Float
  subtotalPrice     Float     @default(0)
  totalDiscounts    Float     @default(0)
  totalTax          Float     @default(0)
  totalShipping     Float     @default(0)
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime
  updatedAt         DateTime
  processedAt       DateTime?
  paidAt            DateTime?
  closedAt          DateTime?
  shopifyCustomerId String?
  customerFirstName String?
  customerLastName  String?
  customerEmail     String?
  tags              String?
  sourceName        String?
  landingSite       String?
  referringSite     String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  isFirstOrder      Boolean   @default(false)
  syncedAt          DateTime  @default(now())

  lineItems    ShopOrderLineItem[]
  refunds      ShopRefund[]
  refundLineItems ShopRefundLineItem[]
  fulfillments ShopFulfillment[]

  @@unique([shop, shopifyOrderId])
  @@index([shop, createdAt])
  @@index([shop, paidAt])
  @@index([shop, financialStatus])
  @@index([shop, shopifyCustomerId])
}

/// 订单行项目（每个 SKU 一条）。
model ShopOrderLineItem {
  id             String  @id @default(cuid())
  shop           String
  shopifyOrderId String
  lineItemId     String
  inventoryItemId String?
  variantId      String?
  productId      String?
  title          String
  variantTitle   String?
  sku            String?
  quantity       Int
  price          Float
  totalDiscount  Float   @default(0)
  vendor         String?

  order ShopOrder @relation(fields: [shop, shopifyOrderId], references: [shop, shopifyOrderId])

  @@unique([shop, lineItemId])
  @@index([shop, shopifyOrderId])
  @@index([shop, sku])
  @@index([shop, inventoryItemId])
  @@index([shop, productId])
}

/// 退款记录（含部分退款）。
model ShopRefund {
  id              String   @id @default(cuid())
  shop            String
  shopifyRefundId String
  shopifyOrderId  String
  refundAmount    Float    @default(0)
  refundNote      String?
  reason          String?
  processedAt     DateTime
  createdAt       DateTime
  syncedAt        DateTime @default(now())

  order     ShopOrder            @relation(fields: [shop, shopifyOrderId], references: [shop, shopifyOrderId])
  lineItems ShopRefundLineItem[]

  @@unique([shop, shopifyRefundId])
  @@index([shop, shopifyOrderId])
  @@index([shop, processedAt])
}

/// 閫€娆捐椤圭洰锛岀敤浜?SKU 褰掑洜銆侀€€娆鹃噾棰?Top SKU 鍜屽敭鍚庡缓璁€?
model ShopRefundLineItem {
  id              String @id @default(cuid())
  shop            String
  shopifyRefundId String
  shopifyOrderId  String
  refundLineItemId String
  lineItemId      String
  inventoryItemId String?
  variantId       String?
  productId       String?
  title           String?
  variantTitle    String?
  sku             String?
  quantity        Int    @default(0)
  subtotal        Float  @default(0)
  totalTax        Float  @default(0)
  reason          String?
  restockType     String?
  createdAt       DateTime @default(now())
  syncedAt        DateTime @default(now())

  refund ShopRefund @relation(fields: [shop, shopifyRefundId], references: [shop, shopifyRefundId], onDelete: Cascade)
  order   ShopOrder  @relation(fields: [shop, shopifyOrderId], references: [shop, shopifyOrderId])

  @@unique([shop, refundLineItemId])
  @@index([shop, shopifyRefundId])
  @@index([shop, shopifyOrderId])
  @@index([shop, lineItemId])
  @@index([shop, sku])
  @@index([shop, reason])
}

/// 客户信息快照（首单/末单/LTV）。
model ShopCustomer {
  id                String    @id @default(cuid())
  shop              String
  shopifyCustomerId String
  email             String?
  phone             String?
  firstName         String?
  lastName          String?
  ordersCount       Int       @default(0)
  totalSpent        Float     @default(0)
  firstOrderDate    DateTime?
  lastOrderDate     DateTime?
  /// active | disabled | declined
  state             String?
  tags              String?
  acceptsMarketing  Boolean   @default(false)
  createdAt         DateTime
  updatedAt         DateTime
  syncedAt          DateTime  @default(now())

  @@unique([shop, shopifyCustomerId])
  @@index([shop, email])
  @@index([shop, firstOrderDate])
  @@index([shop, lastOrderDate])
}

/// 多仓库存水位（按 inventory_item × location）。
model ShopInventoryLevel {
  id              String   @id @default(cuid())
  shop            String
  inventoryItemId String
  variantId       String?
  productId       String?
  sku             String?
  productTitle    String?
  variantTitle    String?
  locationId      String
  locationName    String?
  available       Int      @default(0)
  onHand          Int      @default(0)
  committed       Int      @default(0)
  incoming        Int      @default(0)
  updatedAt       DateTime
  syncedAt        DateTime @default(now())

  @@unique([shop, inventoryItemId, locationId])
  @@index([shop, sku])
  @@index([shop, variantId])
  @@index([shop, locationId])
  @@index([shop, available])
}

/// 发货履约记录。
model ShopFulfillment {
  id                   String   @id @default(cuid())
  shop                 String
  shopifyFulfillmentId String
  shopifyOrderId       String
  /// pending | open | success | cancelled | error | failure
  status               String
  trackingCompany      String?
  trackingNumber       String?
  trackingUrl          String?
  /// pre_transit | in_transit | out_for_delivery | delivered | failure
  shipmentStatus       String?
  createdAt            DateTime
  updatedAt            DateTime
  shippedAt            DateTime?
  deliveredAt          DateTime?
  syncedAt             DateTime @default(now())

  order ShopOrder @relation(fields: [shop, shopifyOrderId], references: [shop, shopifyOrderId])

  @@unique([shop, shopifyFulfillmentId])
  @@index([shop, shopifyOrderId])
  @@index([shop, status])
  @@index([shop, createdAt])
}

/// 增量同步游标（记录每类资源的最后同步时间/分页游标）。
model ShopSyncCheckpoint {
  id           String   @id @default(cuid())
  shop         String
  /// orders | refunds | customers | inventory | fulfillments
  resource     String
  lastSyncedAt DateTime
  lastCursor   String?
  updatedAt    DateTime @updatedAt

  @@unique([shop, resource])
}

/// 业务能力 × 模型/提供商的 token 计费系数（运维在 Turso 维护，种子见 `prisma/token-billing-rule-seed.sql`）。
model TokenBillingRule {
  ruleKey       String   @id
  /// 与 `AppEntry` 一致；`*` 表示所有 App 的兜底规则
  appName       String
  /// product_copy | image_prompt | image_generate | picture_translate
  feature       String
  /// 模型标识（如 deepseek-chat、volc-translate）；`_default` 为该 feature 下未匹配模型时的兜底
  modelKey      String
  displayName   String
  /// 记入 Account.usedTokens 前对 token 的乘数（≥0）
  multiplier    Float
  /// 定额计费时的基准 token（可选；未设则用代码内环境变量默认）
  baseTokenCost Int?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([appName, feature, modelKey])
  @@index([appName, feature, enabled])
}
