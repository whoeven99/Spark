{
  "name": "spark",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "dev:yw": "shopify app dev -c shopify.app.yw.toml",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run setup:deploy && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "setup:deploy": "prisma generate",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:studio": "prisma studio",
    "turso:migrate": "npm run turso:migrate:test",
    "turso:migrate:test": "node scripts/turso-migrate.cjs test",
    "turso:migrate:prod": "node scripts/turso-migrate.cjs prod",
    "turso:drop-schema:test": "node scripts/turso-drop-schema-tables.cjs test",
    "turso:drop-schema:prod": "node scripts/turso-drop-schema-tables.cjs prod",
    "render:digest": "node scripts/render-daily-log-digest.cjs",
    "test:render-digest": "node --test scripts/render-log-classify.test.cjs"
